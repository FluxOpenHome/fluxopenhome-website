{.section collection}
<div class="products-page">
  <div class="container">
    <!-- Page Header -->
    <div class="products-header section-header">
      <h1>{title}</h1>
      <p>{description}</p>
    </div>

    <!-- Category Filter Tabs -->
    <div class="product-filter" role="tablist" aria-label="Filter products by category">
      <button class="filter-tab active" data-filter="all" role="tab" aria-selected="true">All</button>
      <button class="filter-tab" data-filter="lighting" role="tab" aria-selected="false">Lighting</button>
      <button class="filter-tab" data-filter="irrigation" role="tab" aria-selected="false">Irrigation</button>
      <button class="filter-tab" data-filter="sensors" role="tab" aria-selected="false">Sensors</button>
      <button class="filter-tab" data-filter="accessories" role="tab" aria-selected="false">Accessories</button>
    </div>

    <!-- Product Grid -->
    <div class="product-grid" role="tabpanel">
      {.repeated section items}
      <div class="product-card" data-category="{.repeated section categories}{@} {.end}">
        <a href="{fullUrl}" class="product-card-link">
          <div class="product-card-image">
            {.section assetUrl}
              <img src="{@}" alt="{title}" loading="lazy" />
            {.or}
              <div class="product-card-placeholder">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5">
                  <rect x="3" y="3" width="18" height="18" rx="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <path d="M21 15l-5-5L5 21"/>
                </svg>
              </div>
            {.end}
          </div>
          <div class="product-card-body">
            {.repeated section tags}
              {.equal? @ "open-source"}
                <span class="badge badge-accent">Open Source</span>
              {.end}
              {.equal? @ "direct-connect"}
                <span class="badge badge-secondary">Direct Connect</span>
              {.end}
            {.end}
            <h3 class="product-card-title">{title}</h3>
            <p class="product-card-excerpt">{excerpt}</p>
            <div class="product-card-footer">
              <span class="product-card-price">{@|product-price}</span>
              <span class="btn btn-outline btn-sm">View Details</span>
            </div>
          </div>
        </a>
      </div>
      {.end}
    </div>

    <!-- Empty State -->
    {.or}
    <div class="products-empty">
      <p>No products found. Check back soon.</p>
    </div>
    {.end}
  </div>
</div>
{.end}

<squarespace:script src="product-filter.js" combo="true" />
