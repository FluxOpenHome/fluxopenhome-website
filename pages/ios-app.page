<div class="ios-app-page">

  <!-- Hero -->
  <section class="app-hero section-dark">
    <div class="container">
      <div class="app-hero-grid">
        <div class="app-hero-content">
          <span class="badge badge-accent">iOS App</span>
          <h1>Flux Controller for iOS</h1>
          <p class="app-hero-subtitle">Control your irrigation from anywhere. Works with both Home Assistant and Direct Connect controllers.</p>
          <div class="app-hero-actions">
            <a href="#" class="btn btn-primary btn-lg">Download on the App Store</a>
          </div>
          <p class="text-sm text-muted" style="margin-top:12px">Requires iOS 16.0 or later. iPhone and iPad.</p>
        </div>
        <div class="app-hero-image">
          <img src="/assets/placeholder-ios-app.svg" alt="Flux Controller iOS App" style="max-width:260px;margin:0 auto;display:block">
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="app-features section">
    <div class="container">
      <div class="section-header">
        <h2>Full Control in Your Pocket</h2>
        <p>Everything you need to manage your irrigation system from your iPhone.</p>
      </div>
      <div class="app-feature-grid">
        <div class="app-feature-item">
          <div class="app-feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0f9b58" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h4>Zone Control</h4>
          <p>Start, stop, and schedule individual zones. See real-time status for every valve in your system.</p>
        </div>
        <div class="app-feature-item">
          <div class="app-feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0f9b58" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h4>Smart Scheduling</h4>
          <p>Set up to 4 start times per day. Configure run durations, repeat cycles, and rain delays.</p>
        </div>
        <div class="app-feature-item">
          <div class="app-feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0f9b58" stroke-width="2"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>
          </div>
          <h4>Weather Monitoring</h4>
          <p>Live weather data integration. See forecasts and let the system skip watering on rainy days.</p>
        </div>
        <div class="app-feature-item">
          <div class="app-feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0f9b58" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h4>Gophr Readings</h4>
          <p>Monitor soil moisture at three depths. View probe status, battery level, and historical data.</p>
        </div>
        <div class="app-feature-item">
          <div class="app-feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0f9b58" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          </div>
          <h4>Push Notifications</h4>
          <p>Get alerted for system events: watering complete, rain sensor triggered, probe readings, and issues.</p>
        </div>
        <div class="app-feature-item">
          <div class="app-feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0f9b58" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h4>Multi-Property</h4>
          <p>Manage multiple irrigation systems from one app. Switch between properties with a tap.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Compatibility -->
  <section class="app-compat section-light">
    <div class="container">
      <div class="section-header">
        <h2>Works With Both Platforms</h2>
        <p>One app for both Home Assistant and Direct Connect controllers.</p>
      </div>
      <div class="app-compat-grid">
        <div class="app-compat-card card">
          <div class="card-body">
            <img src="/assets/icon-homeassistant.svg" alt="" width="40" height="40" style="margin-bottom:16px">
            <h4>Home Assistant</h4>
            <p>Connect via Nabu Casa remote access or local network. Full integration with the Flux Irrigation Add-on. All features available locally.</p>
          </div>
        </div>
        <div class="app-compat-card card">
          <div class="card-body">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#4a90d9" stroke-width="2" style="margin-bottom:16px"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>
            <h4>Direct Connect</h4>
            <p>Connect directly to the Flux cloud management server. No Home Assistant required. Perfect for standalone and commercial installs.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Screenshots placeholder -->
  <section class="app-screenshots section">
    <div class="container">
      <div class="section-header">
        <h2>Screenshots</h2>
        <p>A clean, intuitive interface designed for everyday use.</p>
      </div>
      <squarespace:block-field id="appScreenshots" columns="12" label="App Screenshots" />
    </div>
  </section>

  <!-- CMS Block -->
  <section class="section">
    <div class="container">
      <squarespace:block-field id="iosAppExtra" columns="12" label="Additional App Content" />
    </div>
  </section>
</div>
